{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": ["ES5", "DOM"],
        "isolatedModules": true,
        "strict": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true 
    },
    "include": ["src"]
}
