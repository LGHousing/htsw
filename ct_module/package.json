{
    "name": "htsw-ct-module",
    "version": "1.1.1",
    "description": "HTSL but we don't take no Ls",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "type": "module",
    "scripts": {
        "dev": "npx tsx watch src/testing.ts",
        "build:java": "node --experimental-strip-types ./scripts/compileJava.ts",
        "build": "vite build --mode production && npm run build:java",
        "generate:condition-mappings": "node --experimental-strip-types ./scripts/generateConditionMappingScaffold.ts",
        "format": "npx prettier \"**/*.{ts,json}\" --write"
    },
    "license": "MIT",
    "dependencies": {
        "htsw": "file:../language",
        "long": "^5.3.2",
        "promise-polyfill": "^8.3.0"
    },
    "devDependencies": {
        "@babel/plugin-proposal-class-properties": "^7.0.0",
        "@babel/plugin-transform-classes": "^7.0.0",
        "@babel/preset-env": "^7.0.0",
        "@babel/preset-typescript": "^7.0.0",
        "@rollup/plugin-babel": "^6.0.0",
        "@types/node": "^25.6.0",
        "typescript": "^5.9.3",
        "vite": "^7.0.0"
    }
}
