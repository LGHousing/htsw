{
    "compilerOptions": {
        /* Base Options: */
        "skipLibCheck": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,

        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,

        "strict": true,
        "noImplicitOverride": true,

        "moduleResolution": "node",
        "module": "es2022",
        "target": "es2022",
        "lib": ["es2022"]
    },
    "include": ["src"]
}
