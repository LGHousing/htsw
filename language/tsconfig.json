{
    "compilerOptions": {
        /* Base Options: */
        "skipLibCheck": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,

        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,

        "strict": true,
        "noImplicitOverride": true,
        "types": ["node"],
        "moduleResolution": "bundler",
        "module": "es2022",
        "target": "es2022",
        "lib": ["es2022"]
    },
    "include": ["src"]
}
