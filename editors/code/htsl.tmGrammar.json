{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "HTSL",
    "scopeName": "source.htsl",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#placeholders" },
        { "include": "#keywords" },
        { "include": "#entities" },
        { "include": "#storage-types" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#numbers" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.htsl",
                    "match": "\\/\\/.*"
                },
                {
                    "name": "comment.block.htsl",
                    "begin": "\\/\\*",
                    "end": "\\*\\/",
                    "patterns": [
                        {
                            "include": "#comments"
                        }
                    ]
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.htsl",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.htsl",
                    "match": "\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})"
                },
                {
                    "include": "#placeholders"
                }
            ]
        },
        "placeholders": {
            "name": "string.quoted.placeholder.htsl",
            "begin": "%",
            "end": "%|(?=[\"\\n])",
            "patterns": [
                {
                    "name": "constant.character.escape.htsl",
                    "match": "\\\\."
                }
            ]
        },
        "keywords": {
            "name": "keyword.control.htsl",
            "match": "\\b(goto|loop|if|else|and|or|function|random|exit|define|macro)\\b"
        },
        "entities": {
            "name": "entity.name.function.htsl",
            "match": "\\b(applyLayout|applyPotion|balanceTeam|cancelEvent|changeHealth|hungerLevel|maxHealth|changePlayerGroup|clearEffects|closeMenu|actionBar|displayMenu|title|enchant|failParkour|fullHeal|xpLevel|giveItem|houseSpawn|kill|parkCheck|pause|sound|removeItem|resetInventory|chat|lobby|compassTarget|gamemode|setTeam|tp|consumeItem|launch|changeVelocity|dropItem|blockType|damageAmount|damageCause|doingParkour|fishingEnv|hasItem|hasPotion|isItem|isSneaking|isFlying|health|hunger|portal|canPvp|hasGroup|hasPermission|hasTeam|inRegion|randomint|locX|locY|locZ|unix)\\b"
        },
        "storage-types": {
            "name": "storage.type.htsl",
            "match": "\\b(stat|globalstat|teamstat|var|globalvar|teamvar|placeholder)\\b"
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.htsl",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "operators": {
            "name": "keyword.operator.htsl",
            "match": "==|<=|>=|!=|\\/\\/=|=<|=>|\\+=|-=|\\*=|\\/=|\\/\\/|\\*\\*|[=><!+\\-*\\/]"
        },
        "numbers": {
            "name": "constant.numeric.htsl",
            "match": "\\b\\d+(\\.\\d*)?\\b"
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.delimiter.htsl",
                    "match": "[;,.]"
                },
                {
                    "name": "meta.brace.htsl",
                    "match": "[\\{\\}()\\[\\]]"
                }
            ]
        }
    }
}
