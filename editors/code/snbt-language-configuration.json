{
    "brackets": [
        ["{", "}"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "[", "close": "]", "notIn": ["string"] },
        { "open": "{", "close": "}", "notIn": ["string"] },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'", "close": "'", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        { "open": "[", "close": "]" },
        { "open": "{", "close": "}" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*[\\{\\[]\\s*$",
        "decreaseIndentPattern": "^\\s*[\\}\\]].*$"
    }
}
