{
    "name": "htsw-plus-plus",
    "displayName": "HTSW++",
    "description": "HTSW completions, diagnostics, hints, and more.",
    "version": "2.0.0",
    "license": "MIT",
    "type": "module",
    "repository": {
        "url": "https://github.com/LGHousing/htsw"
    },
    "engines": {
        "vscode": "^1.97.2"
    },
    "scripts": {
        "build": "tsc --noEmit && vite build --mode production",
        "package": "npx @vscode/vsce package --no-dependencies"
    },
    "dependencies": {
        "htsw": "file:../../language",
        "htsw-editor-common": "file:../common"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/vscode": "^1.97",
        "@vscode/vsce": "^3.6",
        "typescript": "^5.7",
        "vite": "^6.1.0"
    },
    "main": "./dist/extension.cjs",
    "activationEvents": [
        "onLanguage:json",
        "onLanguage:jsonc",
        "onLanguage:snbt"
    ],
    "contributes": {
        "languages": [
            {
                "id": "htsl",
                "extensions": [
                    ".htsl"
                ],
                "aliases": [
                    "HTSL",
                    "htsl"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "snbt",
                "extensions": [
                    ".snbt"
                ],
                "aliases": [
                    "SNBT",
                    "snbt"
                ]
            }
        ],
        "grammars": [
            {
                "language": "htsl",
                "scopeName": "source.htsl",
                "path": "./htsl.tmGrammar.json"
            }
        ],
        "jsonValidation": [
            {
                "fileMatch": "import.json",
                "url": "./schemas/import.schema.json"
            },
            {
                "fileMatch": "*.import.json",
                "url": "./schemas/import.schema.json"
            }
        ],
        "configuration": {
            "title": "HTSW++",
            "properties": {
                "htsw.diagnostics.excludeFolders": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Workspace-relative folder prefixes to exclude from HTSW diagnostics."
                }
            }
        }
    }
}
