{
    "name": "htsw-plus-plus",
    "displayName": "HTSW++",
    "description": "HTSW completions, diagnostics, hints, and more.",
    "version": "1.1.1",
    "license": "MIT",
    "type": "module",
    "repository": {
        "url": "https://github.com/LGHousing/htsw"
    },
    "engines": {
        "vscode": "^1.97.2"
    },
    "scripts": {
        "build": "vite build --mode production",
        "package": "npx @vscode/vsce package --no-dependencies"
    },
    "dependencies": {
        "htsw": "file:../../language",
        "htsw-editor-common": "file:../common"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/vscode": "^1.97",
        "@vscode/vsce": "^3.6",
        "typescript": "^5.7",
        "vite": "^6.1.0"
    },
    "main": "./dist/extension.cjs",
    "activationEvents": [
        "onLanguage:htsl",
        "onLanguage:json",
        "onLanguage:jsonc"
    ],
    "contributes": {
        "languages": [
            {
                "id": "htsl",
                "extensions": [
                    ".htsl"
                ],
                "aliases": [
                    "HTSL",
                    "htsl"
                ]
            }
        ],
        "grammars": [
            {
                "language": "htsl",
                "scopeName": "source.htsl",
                "path": "./htsl.tmGrammar.json"
            }
        ],
        "jsonValidation": [
            {
                "fileMatch": "import.json",
                "url": "./schemas/import.schema.json"
            },
            {
                "fileMatch": "*.import.json",
                "url": "./schemas/import.schema.json"
            }
        ]
    }
}
