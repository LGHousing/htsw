{
    "name": "htsw-plus-plus",
    "displayName": "HTSW++",
    "description": "HTSW completions, diagnostics, hints, and more.",
    "version": "2.0.0",
    "license": "MIT",
    "type": "module",
    "repository": {
        "url": "https://github.com/LGHousing/htsw"
    },
    "engines": {
        "vscode": "^1.97.2"
    },
    "scripts": {
        "build": "tsc --noEmit && vite build --mode production",
        "package": "npx @vscode/vsce package --no-dependencies"
    },
    "dependencies": {
        "htsw": "file:../../language",
        "htsw-editor-common": "file:../common"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/vscode": "^1.97",
        "@vscode/vsce": "^3.6",
        "typescript": "^5.7",
        "vite": "^6.1.0"
    },
    "main": "./dist/extension.cjs",
    "activationEvents": [
        "onLanguage:json",
        "onLanguage:jsonc",
        "onLanguage:snbt"
    ],
    "contributes": {
        "languages": [
            {
                "id": "htsl",
                "extensions": [
                    ".htsl"
                ],
                "aliases": [
                    "HTSL",
                    "htsl"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "snbt",
                "extensions": [
                    ".snbt"
                ],
                "aliases": [
                    "SNBT",
                    "snbt"
                ],
                "configuration": "./snbt-language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "htsl",
                "scopeName": "source.htsl",
                "path": "./htsl.tmGrammar.json"
            },
            {
                "language": "snbt",
                "scopeName": "source.snbt",
                "path": "./snbt.tmGrammar.json"
            }
        ],
        "jsonValidation": [
            {
                "fileMatch": "import.json",
                "url": "./schemas/import.schema.json"
            },
            {
                "fileMatch": "*.import.json",
                "url": "./schemas/import.schema.json"
            }
        ],
        "configuration": {
            "title": "HTSW++",
            "properties": {
                "htsw.diagnostics.excludeFolders": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Workspace-relative folder prefixes to exclude from HTSW diagnostics."
                },
                "htsw.snbt.suggestLoreSplitting": {
                    "type": "boolean",
                    "default": false,
                    "description": "Offer a code action to split long Lore strings into optimally-sized lines for Minecraft tooltips. When the cursor is on a string inside a Lore: [...] list, a 'Split lore line for optimal display' refactor becomes available."
                },
                "htsw.snbt.loreLineMaxWidth": {
                    "type": "number",
                    "default": 40,
                    "minimum": 8,
                    "description": "Max unformatted character width per Lore line when applying 'Split lore line for optimal display'. Format codes (&a, &7, etc.) are not counted; placeholders like %player.name% are treated as 4-character tokens."
                }
            }
        },
        "configurationDefaults": {
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    { "scope": "constant.character.format-code.color.black.snbt",         "settings": { "foreground": "#000000" } },
                    { "scope": "constant.character.format-code.color.dark-blue.snbt",     "settings": { "foreground": "#0000AA" } },
                    { "scope": "constant.character.format-code.color.dark-green.snbt",    "settings": { "foreground": "#00AA00" } },
                    { "scope": "constant.character.format-code.color.dark-aqua.snbt",     "settings": { "foreground": "#00AAAA" } },
                    { "scope": "constant.character.format-code.color.dark-red.snbt",      "settings": { "foreground": "#AA0000" } },
                    { "scope": "constant.character.format-code.color.dark-purple.snbt",   "settings": { "foreground": "#AA00AA" } },
                    { "scope": "constant.character.format-code.color.gold.snbt",          "settings": { "foreground": "#FFAA00" } },
                    { "scope": "constant.character.format-code.color.gray.snbt",          "settings": { "foreground": "#AAAAAA" } },
                    { "scope": "constant.character.format-code.color.dark-gray.snbt",     "settings": { "foreground": "#555555" } },
                    { "scope": "constant.character.format-code.color.blue.snbt",          "settings": { "foreground": "#5555FF" } },
                    { "scope": "constant.character.format-code.color.green.snbt",         "settings": { "foreground": "#55FF55" } },
                    { "scope": "constant.character.format-code.color.aqua.snbt",          "settings": { "foreground": "#55FFFF" } },
                    { "scope": "constant.character.format-code.color.red.snbt",           "settings": { "foreground": "#FF5555" } },
                    { "scope": "constant.character.format-code.color.light-purple.snbt",  "settings": { "foreground": "#FF55FF" } },
                    { "scope": "constant.character.format-code.color.yellow.snbt",        "settings": { "foreground": "#FFFF55" } },
                    { "scope": "constant.character.format-code.color.white.snbt",         "settings": { "foreground": "#FFFFFF" } },
                    { "scope": "constant.character.format-code.style.bold.snbt",          "settings": { "fontStyle": "bold" } },
                    { "scope": "constant.character.format-code.style.italic.snbt",        "settings": { "fontStyle": "italic" } },
                    { "scope": "constant.character.format-code.style.underline.snbt",     "settings": { "fontStyle": "underline" } },
                    { "scope": "constant.character.format-code.style.strikethrough.snbt", "settings": { "fontStyle": "strikethrough" } }
                ]
            }
        }
    }
}
