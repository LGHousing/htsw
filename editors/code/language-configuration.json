{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")", "notIn": ["string"] },
        { "open": "[", "close": "]", "notIn": ["string"] },
        { "open": "{", "close": "}", "notIn": ["string"] },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "/*", "close": "*/", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"" }
    ],
    "onEnterRules": [
        {
            "beforeText": "^\\s*if(?:\\s+(?:and|or|true|false))?\\s*\\(\\s*(?://.*)?$",
            "action": {
                "indent": "indent"
            }
        }
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*.*\\{\\s*(?://.*)?$",
        "decreaseIndentPattern": "^\\s*\\}\\s*(?://.*)?$"
    }
}
