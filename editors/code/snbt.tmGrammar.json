{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "SNBT",
    "scopeName": "source.snbt",
    "patterns": [
        { "include": "#value" }
    ],
    "repository": {
        "value": {
            "patterns": [
                { "include": "#compound" },
                { "include": "#array" },
                { "include": "#string-double" },
                { "include": "#string-single" },
                { "include": "#constant" },
                { "include": "#number" }
            ]
        },
        "compound": {
            "begin": "\\{",
            "end": "\\}",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.dictionary.begin.snbt" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.dictionary.end.snbt" }
            },
            "patterns": [
                {
                    "match": "(\"(?:[^\"\\\\]|\\\\.)*\")\\s*(:)",
                    "captures": {
                        "1": { "name": "support.type.property-name.snbt string.quoted.double.snbt" },
                        "2": { "name": "punctuation.separator.dictionary.key-value.snbt" }
                    }
                },
                {
                    "match": "('(?:[^'\\\\]|\\\\.)*')\\s*(:)",
                    "captures": {
                        "1": { "name": "support.type.property-name.snbt string.quoted.single.snbt" },
                        "2": { "name": "punctuation.separator.dictionary.key-value.snbt" }
                    }
                },
                {
                    "match": "([A-Za-z0-9+\\-._]+)\\s*(:)",
                    "captures": {
                        "1": { "name": "support.type.property-name.snbt" },
                        "2": { "name": "punctuation.separator.dictionary.key-value.snbt" }
                    }
                },
                {
                    "name": "punctuation.separator.dictionary.pair.snbt",
                    "match": ","
                },
                { "include": "#value" }
            ]
        },
        "array": {
            "begin": "\\[",
            "end": "\\]",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.array.begin.snbt" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.array.end.snbt" }
            },
            "patterns": [
                {
                    "match": "\\G\\s*([BbSsIiLl])\\s*(;)",
                    "captures": {
                        "1": { "name": "storage.type.array.snbt" },
                        "2": { "name": "punctuation.separator.array.type.snbt" }
                    }
                },
                {
                    "name": "punctuation.separator.array.snbt",
                    "match": ","
                },
                { "include": "#value" }
            ]
        },
        "string-double": {
            "name": "string.quoted.double.snbt",
            "begin": "\"",
            "end": "\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.snbt" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.snbt" }
            },
            "patterns": [
                { "include": "#string-escape" },
                { "include": "#format-code" }
            ]
        },
        "string-single": {
            "name": "string.quoted.single.snbt",
            "begin": "'",
            "end": "'",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.snbt" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.snbt" }
            },
            "patterns": [
                { "include": "#string-escape" }
            ]
        },
        "string-escape": {
            "name": "constant.character.escape.snbt",
            "match": "\\\\."
        },
        "format-code": {
            "patterns": [
                { "name": "constant.character.format-code.color.black.snbt",         "begin": "[&§][0]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.dark-blue.snbt",     "begin": "[&§][1]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.dark-green.snbt",    "begin": "[&§][2]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.dark-aqua.snbt",     "begin": "[&§][3]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.dark-red.snbt",      "begin": "[&§][4]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.dark-purple.snbt",   "begin": "[&§][5]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.gold.snbt",          "begin": "[&§][6]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.gray.snbt",          "begin": "[&§][7]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.dark-gray.snbt",     "begin": "[&§][8]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.blue.snbt",          "begin": "[&§][9]",   "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.green.snbt",         "begin": "[&§][aA]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.aqua.snbt",          "begin": "[&§][bB]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.red.snbt",           "begin": "[&§][cC]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.light-purple.snbt",  "begin": "[&§][dD]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.yellow.snbt",        "begin": "[&§][eE]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.color.white.snbt",         "begin": "[&§][fF]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.style.obfuscated.snbt",    "begin": "[&§][kK]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.style.bold.snbt",          "begin": "[&§][lL]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.style.strikethrough.snbt", "begin": "[&§][mM]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.style.underline.snbt",     "begin": "[&§][nN]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.style.italic.snbt",        "begin": "[&§][oO]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] },
                { "name": "constant.character.format-code.style.reset.snbt",         "begin": "[&§][rR]",  "end": "(?=[&§][0-9a-fA-Fk-oK-OrR]|\")", "patterns": [{ "include": "#string-escape" }] }
            ]
        },
        "constant": {
            "name": "constant.language.snbt",
            "match": "\\b(true|false)\\b"
        },
        "number": {
            "patterns": [
                {
                    "name": "constant.numeric.float.snbt",
                    "match": "-?\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?[fFdD]\\b"
                },
                {
                    "name": "constant.numeric.float.snbt",
                    "match": "-?\\b\\d+(?:\\.\\d+(?:[eE][+-]?\\d+)?|[eE][+-]?\\d+)\\b"
                },
                {
                    "name": "constant.numeric.integer.snbt",
                    "match": "-?\\b\\d+[bBsSiIlL]?\\b"
                }
            ]
        }
    }
}
